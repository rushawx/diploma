# Database Configuration
PG_HOST=db
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=recs

# Database Connection Pooling
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false
DB_AUTOCOMMIT=false
DB_AUTOFLUSH=false

# Data Configuration
DATA_PATH=data.xlsx

# Model Configuration
TRANSFORMER_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# Processing Configuration
BATCH_SIZE=100
SKIP_EMBEDDING=false
STOP_ON_ERROR=true

# Logging Configuration
LOG_LEVEL=INFO