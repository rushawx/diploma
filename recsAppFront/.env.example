# Backend Configuration
BACKEND_URL=back:8080
BACKEND_TIMEOUT=10
USE_HTTPS=false

# Authentication Configuration
TOKEN_EXPIRE_MINUTES=30
AUTO_LOGOUT_ENABLED=true

# UI Configuration
APP_TITLE=Student Projects Recommender System
PAGE_ICON=🎓
LAYOUT=wide

# ML/Transformer Configuration
TRANSFORMER_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
TRANSFORMER_CACHE_TTL=10m

# Data Configuration
DATA_CACHE_TTL=10m

# Search Configuration
DEFAULT_TOP_K=5
MIN_SIMILARITY_THRESHOLD=0.1

# UI Messages
LOADING_DATA_MESSAGE=Loading data...
LOADING_EMBEDDINGS_MESSAGE=Loading vector representations...
LOADING_TRANSFORMER_MESSAGE=Loading transformer...

# Error Messages
CONNECTION_ERROR_MESSAGE=Connection error: {}
AUTH_ERROR_MESSAGE=Authentication failed. Please login again.
SESSION_EXPIRED_MESSAGE=Session expired. Please login again.

# Feature Flags
ENABLE_CACHING=true
ENABLE_DEBUG_MODE=false

# Logging Configuration
LOG_LEVEL=INFO

# PyTorch/Device Configuration
# Options: "cpu", "cuda", "auto" (default: auto)
# PYTORCH_DEVICE=cpu
# FORCE_CPU=true
# PYTORCH_THREADS=4